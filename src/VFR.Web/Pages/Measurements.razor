@page "/measurements"
@inject ProfileApiClient ProfileApi
@inject AuthService AuthSvc
@inject NavigationManager Nav
@using VFR.Web.Services

@if (!AuthSvc.IsAuthenticated) { Nav.NavigateTo("/login"); }

<div class="page-container">
    <div class="setup-card glass">
        <h2>📏 Detailed Measurements</h2>
        <p class="hint">Optional but improves avatar accuracy significantly.</p>

        <EditForm Model="model" OnValidSubmit="HandleSubmit">
            <div class="measurements-grid">
                <div class="form-group">
                    <label>Chest (cm)</label>
                    <InputNumber @bind-Value="model.Chest" class="form-input" min="50" max="200"/>
                </div>
                <div class="form-group">
                    <label>Waist (cm)</label>
                    <InputNumber @bind-Value="model.Waist" class="form-input" min="40" max="200"/>
                </div>
                <div class="form-group">
                    <label>Hip (cm)</label>
                    <InputNumber @bind-Value="model.Hip" class="form-input" min="50" max="200"/>
                </div>
                <div class="form-group">
                    <label>Shoulder Width (cm)</label>
                    <InputNumber @bind-Value="model.Shoulder" class="form-input" min="30" max="80"/>
                </div>
            </div>

            @if (errorMessage is not null) { <div class="error-banner">@errorMessage</div> }
            @if (successMessage is not null) { <div class="success-banner">@successMessage</div> }

            <div class="form-actions">
                <a href="/avatar" class="btn-secondary">Skip →</a>
                <button type="submit" class="btn-primary" disabled="@isLoading">
                    @if (isLoading) { <span class="spinner"></span> } else { <span>Update Avatar →</span> }
                </button>
            </div>
        </EditForm>
    </div>
</div>

@code {
    private MeasurementsModel model = new();
    private string? errorMessage;
    private string? successMessage;
    private bool isLoading;

    private async Task HandleSubmit()
    {
        isLoading = true;
        errorMessage = null;
        successMessage = null;

        var (profile, error) = await ProfileApi.UpdateMeasurementsAsync(
            model.Chest, model.Waist, model.Hip, model.Shoulder);

        isLoading = false;

        if (profile is not null) Nav.NavigateTo("/avatar");
        else errorMessage = error ?? "Update failed.";
    }

    private class MeasurementsModel
    {
        public decimal? Chest    { get; set; }
        public decimal? Waist    { get; set; }
        public decimal? Hip      { get; set; }
        public decimal? Shoulder { get; set; }
    }
}
