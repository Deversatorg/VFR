@page "/register"
@inject AuthApiClient Auth
@inject NavigationManager Nav
@using VFR.Web.Services

<div class="auth-container">
    <div class="auth-card glass">
        <div class="auth-logo">
            <span class="logo-icon">👗</span>
            <h1>Create Account</h1>
            <p class="subtitle">Join the Virtual Fitting Room</p>
        </div>

        <EditForm Model="model" OnValidSubmit="HandleRegister" class="auth-form">
            <DataAnnotationsValidator/>

            <div class="form-group">
                <label>Username</label>
                <InputText @bind-Value="model.UserName" class="form-input" placeholder="johndoe"/>
            </div>

            <div class="form-group">
                <label>Email</label>
                <InputText @bind-Value="model.Email" class="form-input" placeholder="you@example.com" type="email"/>
            </div>

            <div class="form-group">
                <label>Password</label>
                <InputText @bind-Value="model.Password" class="form-input" placeholder="Min. 6 characters" type="password"/>
            </div>

            <div class="form-group">
                <label>Confirm Password</label>
                <InputText @bind-Value="model.ConfirmPassword" class="form-input" placeholder="Repeat password" type="password"/>
            </div>

            @if (errorMessage is not null)
            {
                <div class="error-banner">@errorMessage</div>
            }
            @if (successMessage is not null)
            {
                <div class="success-banner">@successMessage</div>
            }

            <button type="submit" class="btn-primary" disabled="@isLoading">
                @if (isLoading) { <span class="spinner"></span> } else { <span>Create Account</span> }
            </button>
        </EditForm>

        <div class="auth-footer">
            <p>Already have an account? <a href="/login">Sign in</a></p>
        </div>
    </div>
</div>

@code {
    private RegisterModel model = new();
    private string? errorMessage;
    private string? successMessage;
    private bool isLoading;

    private async Task HandleRegister()
    {
        isLoading = true;
        errorMessage = null;
        successMessage = null;

        var (success, error) = await Auth.RegisterAsync(
            model.Email, model.UserName, model.Password, model.ConfirmPassword);

        isLoading = false;

        if (success)
        {
            successMessage = "Account created! Check your email to confirm, then sign in.";
        }
        else errorMessage = error ?? "Registration failed.";
    }

    private class RegisterModel
    {
        public string UserName    { get; set; } = "";
        public string Email       { get; set; } = "";
        public string Password    { get; set; } = "";
        public string ConfirmPassword { get; set; } = "";
    }
}
