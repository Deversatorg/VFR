@page "/avatar"
@inject AuthService AuthSvc
@inject NavigationManager Nav
@using VFR.Web.Services
@using VFR.Web.Components

@if (!AuthSvc.IsAuthenticated) { Nav.NavigateTo("/login"); }

<div class="viewer-page">
    <div class="viewer-panel glass">
        <div class="viewer-header">
            <h2>🧍 Your Avatar</h2>
            <div class="viewer-actions">
                <a href="/measurements" class="btn-secondary btn-sm">Update Measurements</a>
            </div>
        </div>

        <AvatarCanvas AvatarUrl="@avatarUrl"/>

        <div class="viewer-footer">
            <span class="hint">Drag to rotate · Scroll to zoom</span>
        </div>
    </div>
</div>

@code {
    // TODO: load real avatarUrl from ProfileApi state (Phase 5)
    private string avatarUrl = "https://storage.vfr.dev/models/default_regular.glb";
}
